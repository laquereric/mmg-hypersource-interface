@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix g:    <urn:mm:grammar:hypersource#> .

# GENERATED from grammar.bnf + boundary.ttl by Mmg::Optimize::GrammarShacl -- do not hand-edit.
# SHACL is the gem's SECOND grammar (data shapes), derived so it cannot drift from the message grammar.
# Used symmetrically: IN shapes accept-as-API-input; OUT shapes validate the graph-out projection.

# --- grammar-in: API INPUT shapes (accept-as-input), one per <statement> command ---
g:OpenArcRequest a sh:NodeShape ;
  rdfs:comment "input for the 'open_arc' command" ;
  sh:property [ sh:path g:title ; sh:datatype xsd:string ; sh:minCount 0 ; sh:maxCount 1 ] .

g:BranchRequest a sh:NodeShape ;
  rdfs:comment "input for the 'branch' command" ;
  sh:property [ sh:path g:arc_id ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] .

g:WorktreeRequest a sh:NodeShape ;
  rdfs:comment "input for the 'worktree' command" ;
  sh:property [ sh:path g:arc_id ; sh:datatype xsd:string ; sh:minCount 0 ; sh:maxCount 1 ] ;
  sh:property [ sh:path g:brief_id ; sh:datatype xsd:string ; sh:minCount 0 ; sh:maxCount 1 ] ;
  sh:property [ sh:path g:engine ; sh:datatype xsd:string ; sh:minCount 0 ; sh:maxCount 1 ] .

g:ArcForBriefRequest a sh:NodeShape ;
  rdfs:comment "input for the 'arc_for_brief' command" ;
  sh:property [ sh:path g:brief_id ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] .

g:SyncRequest a sh:NodeShape ;
  rdfs:comment "input for the 'sync' command" ;
  sh:property [ sh:path g:arc_id ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] .

# --- graph-out: projection shapes (from boundary.ttl concepts) ---
g:ArcShape a sh:NodeShape ;
  sh:targetClass g:Arc ;
  rdfs:comment "projected arc" ;
  sh:property [ sh:path g:branch ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] ;
  sh:property [ sh:path g:worktree ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ] .
